# =============================================================================
# Weather Application - Environment Configuration
# =============================================================================
# This file serves as a template for environment variables required by the
# weather application. Copy this file to .env and fill in your actual values.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your actual API keys and configuration
# =============================================================================

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------

# OpenWeatherMap API Key
# Sign up at https://openweathermap.org/api to get your free API key
# Required for fetching real-time weather data
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key_here

# API Base URL (optional - defaults to OpenWeatherMap free tier)
# Change if using a different API provider or self-hosted service
# WEATHER_API_BASE_URL=https://api.openweathermap.org/data/2.5

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------

# Server port (default: 3000)
# PORT=3000

# Server host (default: localhost)
# HOST=localhost

# Node environment (development, production, test)
# NODE_ENV=development

# -----------------------------------------------------------------------------
# Database Configuration (optional)
# -----------------------------------------------------------------------------

# Database connection string (if using a database for caching or history)
# DATABASE_URL=postgresql://user:password@localhost:5432/weather_app

# Redis connection string (if using Redis for caching)
# REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Security & Rate Limiting
# -----------------------------------------------------------------------------

# Rate limiting configuration
# RATE_LIMIT_WINDOW_MS=900000  # 15 minutes in milliseconds
# RATE_LIMIT_MAX_REQUESTS=100

# CORS allowed origins (comma-separated)
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# -----------------------------------------------------------------------------
# Logging & Monitoring
# -----------------------------------------------------------------------------

# Log level (error, warn, info, debug)
# LOG_LEVEL=info

# Enable request logging
# ENABLE_REQUEST_LOGGING=true

# -----------------------------------------------------------------------------
# Cache Configuration
# -----------------------------------------------------------------------------

# Cache TTL in seconds (default: 600 = 10 minutes)
# CACHE_TTL_SECONDS=600

# Enable in-memory caching
# ENABLE_CACHE=true

# -----------------------------------------------------------------------------
# Frontend Configuration
# -----------------------------------------------------------------------------

# Frontend API base URL (default: http://localhost:3000/api)
# VITE_API_BASE_URL=http://localhost:3000/api

# -----------------------------------------------------------------------------
# IMPORTANT NOTES
# -----------------------------------------------------------------------------
# 1. Never commit your actual .env file to version control
# 2. Keep your API keys secure and rotate them regularly
# 3. Use different API keys for development and production
# 4. Add .env to your .gitignore file
# 5. For production, use a secrets manager instead of .env files
# =============================================================================